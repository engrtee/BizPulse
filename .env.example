# ============================================================
# BIZPULSE — ENVIRONMENT VARIABLE TEMPLATE
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in each value following the instructions below
# 3. Never commit .env — it is git-ignored
# ============================================================

# WHATSAPP (fill when Meta approves your Business API)
WHATSAPP_PHONE_NUMBER_ID=          # e.g. 123456789012345
WHATSAPP_TOKEN=                    # Bearer token from Meta dashboard
WHATSAPP_VERIFY_TOKEN=bizpulse_webhook_2026   # Keep this value — matches Meta webhook config
WHATSAPP_APP_SECRET=               # From Meta App Dashboard → App Settings → App Secret (used for webhook signature verification)
BIZPULSE_NUMBER=                   # e.g. +2348012345678

# AI
GEMINI_API_KEY=                    # From Google AI Studio — starts with AIza...
ANTHROPIC_API_KEY=                 # From Anthropic Console — starts with sk-ant-... (required for Kemi agent)

# DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/bizpulse

# EMAIL (via Brevo — NOT Gmail/nodemailer)
BREVO_API_KEY=                     # From Brevo dashboard — used for transactional emails
BREVO_FROM_EMAIL=                  # Verified sender email address in Brevo

# APP & FRONTEND
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000  # URL users click to access dashboard (used for CORS origin)
PORT=3000
NODE_ENV=development
ADMIN_PASSWORD=                    # password for /admin dashboard — send via X-Admin-Password header
