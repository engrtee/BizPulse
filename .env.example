# ============================================================
# BIZPULSE — ENVIRONMENT VARIABLE TEMPLATE
# ============================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in each value following the instructions below
# 3. Never commit .env — it is git-ignored
# ============================================================

# WHATSAPP (fill when Meta approves your Business API)
WHATSAPP_PHONE_NUMBER_ID=          # e.g. 123456789012345
WHATSAPP_TOKEN=                    # Bearer token from Meta dashboard
WHATSAPP_VERIFY_TOKEN=bizpulse_webhook_2026   # Keep this value — matches Meta webhook config
BIZPULSE_NUMBER=                   # e.g. +2348012345678

# GOOGLE
GOOGLE_CLIENT_ID=                  # ends in .apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=              # short alphanumeric string
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# GEMINI AI
GEMINI_API_KEY=                    # starts with AIza...

# DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/bizpulse

# EMAIL
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=                # 16-char app password from Google Account

# APP
BASE_URL=http://localhost:3000
PORT=3000
NODE_ENV=development
